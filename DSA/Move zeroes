* Given an array, move all 0s to the end while maintaining the relative order of non-zero elements.
* Input:  [0, 1, 0, 3, 12]
  Output: [1, 3, 12, 0, 0]

* Brute Force ==========
    function moveZeros(arr) {
      const result = [];
    
      for (let num of arr) {
        if (num !== 0) result.push(num);
      }
    
      while (result.length < arr.length) {
        result.push(0);
      }
    
      return result;
    }

